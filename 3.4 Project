from datetime import datetime

def convertData(value, conversionType):
    if conversionType == "F":
        return (value - 32) * 5/9
    elif conversionType == "LBS":
        return value / 2.205
    elif conversionType == "IN":
        return value * 2.54
    else:
        return None

def getInput():
    count = int(input("How many entries are being entered? "))

    for i in range(count):
        date = input("Enter the date (MM/DD/YYYY): ")

        value = float(input("Enter the numerical value: "))

        conversionType = input("Enter type (F for Fahrenheit, LBS for pounds, IN for inches): ").upper()

        converted = convertData(value, conversionType)

        print(f"\nThe following was saved at {datetime.now()}:")
        print(f"Date: {date}")
        print(f"Original Value: {value}")
        print(f"Converted Value: {converted}\n")

