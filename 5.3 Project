import csv
import openpyxl
from openpyxl.chart import LineChart, BarChart, Reference
from datetime import datetime

# createChart(path: str, chartType: str) -> None
# Takes a CSV file path and a chart type ("line" or "bar")
# Creates Excel file final.xlsx and generates the appropriate chart
def createChart(path, chartType):
    print("Choose data source:")
    print("1. Original data (pounds/inches/Fahrenheit)")
    print("2. Converted data (kilograms/centimeters/Celsius)")
    choice = input("Enter 1 or 2: ")

    dates = []
    values = []

    with open(path, "r") as file:
        reader = csv.DictReader(file)
        for row in reader:
            dates.append(row["Date"])
            if choice == "1":
                values.append(float(row["Original"]))
            else:
                values.append(float(row["Converted"]))

    wb = openpyxl.Workbook()
    ws = wb.active
    ws.title = "Data"

    ws.append(["Date", "Value"])
    for d, v in zip(dates, values):
        ws.append([d, v])

    dataRef = Reference(ws, min_col=2, min_row=2, max_row=len(values) + 1)
    labelRef = Reference(ws, min_col=1, min_row=2, max_row=len(values) + 1)

    if chartType == "line":
        chart = LineChart()
    else:
        chart = BarChart()

    chart.add_data(dataRef)
    chart.set_categories(labelRef)
    chart.x_axis.title = "Date"
    chart.y_axis.title = "Value"

    today = datetime.now().strftime("%m/%d/%Y")
    chart.title = f"Cambel8058 {today}"

    ws.add_chart(chart, "E5")
    wb.save("final.xlsx")


# generateReport(path: str) -> None
# Asks user for chart type and calls createChart()
def generateReport(path):
    print("Choose chart type:")
    print("1. Line Chart")
    print("2. Bar Chart")
    choice = input("Enter 1 or 2: ")

    if choice == "1":
        createChart(path, "line")
    else:
        createChart(path, "bar")


# Main menu
def mainMenu():
    while True:
        print("\nMAIN MENU")
        print("1. Option One")
        print("2. Option Two")
        print("3. Generate Report")
        print("4. Exit")

        choice = input("Enter choice: ")

        if choice == "1":
            print("Option One selected.")
        elif choice == "2":
            print("Option Two selected.")
        elif choice == "3":
            generateReport("data.csv")
        elif choice == "4":
            print("Exiting program.")
            break
        else:
            print("Invalid choice.")


mainMenu()
